<style>
  .services-tabs-section .section-head { margin-bottom: 3rem; }
  .services-research-nav {
    display: flex;
    gap: 1rem;
    margin-bottom: 4rem;
    overflow-x: auto;
    padding-bottom: 1rem;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .services-research-nav::-webkit-scrollbar { display: none; }

  .research-tab-btn {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1.2rem 2rem;
    background: rgba(var(--accent-rgb), 0.05);
    border: 1px solid rgba(var(--accent-rgb), 0.1);
    border-radius: 50px;
    color: var(--text-muted);
    font-weight: 600;
    font-size: 0.95rem;
    white-space: nowrap;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .research-tab-btn .tab-icon { font-size: 1.2rem; filter: grayscale(1); transition: filter 0.4s; }
  
  .research-tab-btn:hover {
    background: rgba(var(--accent-rgb), 0.1);
    color: var(--text-light);
    transform: translateY(-2px);
  }

  .research-tab-btn.active {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
    box-shadow: 0 10px 20px rgba(var(--accent-rgb), 0.2);
  }

  .research-tab-btn.active .tab-icon { filter: grayscale(0); }

  .services-grid-container {
    display: none;
    animation: tabFade 0.6s ease forwards;
  }

  .services-grid-container.active { display: block; }

  @keyframes tabFade {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .services-research-nav { padding-left: 1rem; padding-right: 1rem; margin-left: -1rem; margin-right: -1rem; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabBtns = document.querySelectorAll('.research-tab-btn');
    const tabGrids = document.querySelectorAll('.services-grid-container');

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetTab = btn.getAttribute('data-tab');

        // Toggle active button
        tabBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        // Toggle visibility with animation restart
        tabGrids.forEach(grid => {
          grid.classList.remove('active');
          if (grid.id === targetTab) {
            grid.classList.add('active');
          }
        });
      });
    });
  });
</script>
